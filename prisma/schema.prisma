datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  Int              @id @default(autoincrement())
  name                String
  email               String           @unique
  passwordHash        String
  connectionCount     Int              @default(0)
  profileReady        Boolean          @default(false)
  profile             Profile?
  sharingSettings     SharingSettings?
  createdAt           DateTime         @default(now())
  sentConnections     Connection[]     @relation("Requester")
  receivedConnections Connection[]     @relation("Receiver")
  connectionVisibilities ConnectionVisibility[]
}

model Profile {
  id             Int            @id @default(autoincrement())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int            @unique
  name           String
  username       String         @unique
  tagline        String?        @default("Let's connect!")
  avatar         String         @default("/profile_avatar.png")
  isOnline       Boolean        @default(true)
  bio            String?        @default("I design meaningful experiences.")
  phone          String?
  whatsapp       String?
  location       String?
  diamonds       String         @default("0")
  isPremium      Boolean        @default(false)
  tapCount       Int            @default(0)
  tags           Tag[]
  socials        SocialLink[]
  historyEvents  HistoryEvent[]
}

model Tag {
  id        Int     @id @default(autoincrement())
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int
  text      String
  type      String  // "role" | "location"
}

model SocialLink {
  id        Int     @id @default(autoincrement())
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int
  platform  String
  handle    String
  url       String
  icon      String
  color     String
}

model HistoryEvent {
  id        Int      @id @default(autoincrement())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int
  action    String
  details   String
  icon      String?
  color     String?
  createdAt DateTime @default(now())
}

model AppVersion {
  id          Int      @id @default(autoincrement())
  versionName String   @map("version_name")
  buildNumber Int      @map("build_number")
  changelog   String?
  apkUrl      String   @map("apk_url")
  forceUpdate Boolean  @default(false) @map("force_update")
  isCurrent   Boolean  @default(false) @map("is_current")
  isDraft     Boolean  @default(true) @map("is_draft")
  channel     String   @default("stable")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("app_versions")
}

model Connection {
  id          Int      @id @default(autoincrement())
  requesterId Int
  receiverId  Int
  status      String   @default("pending") // pending | accepted | rejected | blocked
  via         String   @default("nfc")     // Default to nfc
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester  User                  @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver   User                  @relation("Receiver",  fields: [receiverId],  references: [id], onDelete: Cascade)
  visibilities ConnectionVisibility[]

  @@unique([requesterId, receiverId])
  @@map("connections")
}

model SharingSettings {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  shareName     Boolean @default(true)
  shareEmail    Boolean @default(true)
  sharePhone    Boolean @default(false)
  shareWhatsapp Boolean @default(true)
  shareLocation Boolean @default(false)

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sharing_settings")
}

model ConnectionVisibility {
  id              Int      @id @default(autoincrement())
  connectionId    Int
  userId          Int
  shareName       Boolean  @default(true)
  shareEmail      Boolean  @default(true)
  sharePhone      Boolean  @default(false)
  shareWhatsapp   Boolean  @default(true)
  shareLocation   Boolean  @default(false)
  sharedSocialIds Int[]

  connection      Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([connectionId, userId])
  @@map("connection_visibilities")
}
