{
  "version": 2,
  "rewrites": [
    { "source": "/api/auth/register", "destination": "/api/auth/register.js" },
    { "source": "/api/auth/login", "destination": "/api/auth/login.js" },
    { "source": "/api/profile/update", "destination": "/api/profile/update.js" },
    { "source": "/api/profile/:username/click", "destination": "/api/profile/click.js?username=:username" },
    { "source": "/api/profile/:username/tap", "destination": "/api/profile/tap.js?username=:username" },
    { "source": "/api/profile/:username", "destination": "/api/profile/get.js?username=:username" },
    { "source": "/api/socials/:id", "destination": "/api/socials/delete.js?id=:id" },
    { "source": "/api/socials", "destination": "/api/socials/index.js" },
    { "source": "/api/analytics", "destination": "/api/analytics/index.js" },
    { "source": "/api/leaderboard", "destination": "/api/leaderboard.js" },
    { "source": "/u/:username", "destination": "/index.html" },
    { "source": "/nfc/:username", "destination": "/nfc/index.html" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
